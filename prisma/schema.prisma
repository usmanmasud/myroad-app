generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Progress {
  id           Int      @id @default(autoincrement())
  weekNum      Int      @unique
  completed    Boolean  @default(false)
  completedAt  DateTime?
  note         String?
  updatedAt    DateTime @updatedAt
}

model Streak {
  id          Int      @id @default(1)
  current     Int      @default(0)
  longest     Int      @default(0)
  lastActiveDate String?
}
